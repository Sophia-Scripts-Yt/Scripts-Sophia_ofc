-- VARIÁVEIS DE CONTROLE
local dragging, dragStart, startPos
local idAcao = 0

-- FUNÇÃO DE TELEPORTE
local function executarTeleporte()
    idAcao = idAcao + 1
    local meuId = idAcao
    
    statusLabel.Text = "⏳ SEGURE... (1.23s)"
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
    
    task.wait(1.23)
    
    if idAcao == meuId then
        statusLabel.Text = "⚡ RECONECTANDO..."
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        
        if #Players:GetPlayers() <= 1 then
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        else
            TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
        end
    end
end

local function cancelar()
    idAcao = idAcao + 1
    statusLabel.Text = "✨ REJOIN PRONTO\n(Segure 1.23s | Arraste)"
    statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
end

-- ARRASTAR (LÓGICA SIMPLIFICADA)
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        
        local movido = false
        local connection
        connection = UIS.InputChanged:Connect(function(change)
            if dragging and (change.UserInputType == Enum.UserInputType.MouseMovement or change.UserInputType == Enum.UserInputType.Touch) then
                local delta = change.Position - dragStart
                if delta.Magnitude > 10 then 
                    movido = true 
                    idAcao = idAcao + 1 -- Cancela se mover
                end
                mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
        
        -- Inicia tentativa de Rejoin se não mover logo
        task.delay(0.15, function()
            if dragging and not movido then executarTeleporte() end
        end)

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
                cancelar()
                if connection then connection:Disconnect() end
            end
        end)
    end
end)

