-- SERVIÇOS
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ProximityPromptService = game:GetService("ProximityPromptService")
local LocalPlayer = Players.LocalPlayer

-- INTERFACE ESTÉTICA
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "RejoinPrecision_V8"
screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 240, 0, 75)
mainFrame.Position = UDim2.new(0.5, -120, 0, 40)
mainFrame.BackgroundColor3 = Color3.fromRGB(15, 0, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true 
mainFrame.Parent = screenGui

-- VARIÁVEIS DE CONTROLE
local dragging = false
local moveDetect = false
local dragStart, startPos, dragInput
local tempoDeEspera = 1.23 -- VALOR ATUALIZADO
local idConexao = 0 

-- FUNÇÃO PRINCIPAL DE REJOIN
local function iniciarContagemRejoin()
    idConexao = idConexao + 1
    local idAtual = idConexao
    
    local statusLabel = mainFrame:FindFirstChild("StatusLabel")
    if statusLabel then
        statusLabel.Text = "⏳ SEGURANDO... (1.23s)"
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
    end

    task.wait(tempoDeEspera)

    -- Verifica se ainda é a mesma tentativa e se não está arrastando
    if idConexao == idAtual and not moveDetect then
        if statusLabel then
            statusLabel.Text = "⚡ RECONECTANDO..."
            statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        end
        
        if #Players:GetPlayers() <= 1 then
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        else
            TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
        end
    end
end

local function cancelarRejoin()
    idConexao = idConexao + 1 
    local statusLabel = mainFrame:FindFirstChild("StatusLabel")
    if statusLabel then
        statusLabel.Text = "✨ REJOIN PRO"
        statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

-- 1. DETECÇÃO DO PROXIMITY PROMPT (BOTÃO DO JOGO)
ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt, player)
    if player == LocalPlayer then
        local txt = string.lower(prompt.ObjectText .. prompt.ActionText)
        if string.find(txt, "rena") or string.find(txt, "rebir") then
            iniciarContagemRejoin()
        end
    end
end)

ProximityPromptService.PromptButtonHoldEnded:Connect(function(prompt, player)
    if player == LocalPlayer then cancelarRejoin() end
end)

-- 2. LÓGICA DE ARRASTAR E CLIQUE NA GUI
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragStart = input.Position
        startPos = mainFrame.Position
        dragging = true
        moveDetect = false
        
        task.spawn(function()
            task.wait(0.2) -- Janela para detectar se é arrasto
            if dragging and not moveDetect then
                iniciarContagemRejoin()
            end
        end)

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
                cancelarRejoin()
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
        if dragStart and (input.Position - dragStart).Magnitude > 8 then
            moveDetect = true
            if dragging then
                idConexao = idConexao + 1
            end
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

